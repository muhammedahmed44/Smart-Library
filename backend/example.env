# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=elibrary_user
DB_PASSWORD=your_strong_password_here
DB_NAME=elibrary

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
COOKIE_SECRET=replace_with_another_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── AI ────────────────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── CORS ──────────────────────────────────────────────────────────────────
# In production with Express serving the frontend, set this to your domain.
# If using a separate frontend deployment, set to that domain.
CLIENT_ORIGIN=https://yourdomain.com

# ── File storage ──────────────────────────────────────────────────────────
# Use an absolute path in production, e.g. /var/www/elibrary/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
